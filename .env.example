# Supabase
# Local dev values come from `npx supabase status`.
# For production, copy from your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Used by the book seeding script and cache writes. Never expose to the client.
SUPABASE_SECRET_KEY=

# OpenAI — used for text-embedding-3-small
OPENAI_API_KEY=

# MyAnimeList API client ID (required for MAL public endpoints).
# Create one at https://myanimelist.net/apiconfig
MAL_CLIENT_ID=

# AniList GraphQL requires no API key.
